# MongoDB Atlas → Connect → Drivers (encode special chars in password, e.g. @ → %40)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/carbook?retryWrites=true&w=majority

# Optional: only if you must override the database name from the URI
# MONGODB_DB_NAME=carbook

# Collection name for Sejal contact form (default: sejal_contacts)
# MONGODB_CONTACTS_COLLECTION=sejal_contacts

# Optional (default 4000)
# PORT=4000

# Saved on each contact in Atlas (defaults match sm-tech/src/config.js if unset)
# OFFICE_ADDRESS=Nanded Dist., Maharashtra 431717
# OFFICE_MAPS_URL=https://www.google.com/maps/search/?api=1&query=Nanded%2C%20Maharashtra%20431717

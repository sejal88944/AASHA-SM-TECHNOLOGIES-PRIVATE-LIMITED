# Copy this file to `.env` for local development (do not commit secrets).

# Canonical site origin (no trailing slash)
VITE_SITE_URL=https://smtechsolutions.in

# Used by `scripts/generate-seo-files.mjs` during builds (Vercel: set in Project Settings too)
SITE_URL=https://smtechsolutions.in

# Contact form delivery. Configure at least one of MONGODB_URI or CONTACT_WEBHOOK_URL
# in production; otherwise /api/contact rejects submissions instead of losing leads.
#
# MongoDB Atlas (same URI as sejal backend; set in Vercel Production).
# Database name is taken from the URI path (e.g. .../carbook?...).
# For `npm run dev` (Vite): set `MONGODB_URI` here — dev server serves POST /api/contact and writes to MongoDB.
MONGODB_URI=

# Optional alternative/additional delivery sink for automations.
# CONTACT_WEBHOOK_URL=

# Optional — collection for website leads (default: sejal_contacts)
# MONGODB_CONTACTS_COLLECTION=sejal_contacts

# Optional: stored on each lead (same idea as sejal backend defaults)
# OFFICE_ADDRESS=
# OFFICE_MAPS_URL=

# Optional: override contact POST URL (defaults to /api/contact)
# VITE_CONTACT_ENDPOINT=/api/contact

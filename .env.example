# Copy to .env or .env.development.local (not committed) and adjust.
# No quotes, no spaces around =. Prefix must be REACT_APP_ for Create React App.

# Local: sejal-api default port
REACT_APP_API_URL=http://localhost:4000

# Production build with a separate API (Render, etc.) — set before npm run build, or in Vercel/Render env:
# REACT_APP_API_URL=https://your-backend.onrender.com

# =============================================================================
# Frontend (Vite) — copy to ".env" for local dev:  cp .env.example .env
# Only variables prefixed with VITE_ are exposed to the browser (build-time).
# =============================================================================

# --- Contact form (local) ---
# 1 (default): dev server mocks POST /api/contact (no MongoDB needed locally)
# 0: proxy /api to local Express (see VITE_API_PORT) — run backend on that port
VITE_CONTACT_MOCK=1

# Port for local Express API when VITE_CONTACT_MOCK=0
VITE_API_PORT=4000

# Optional: full URL to contact API (e.g. another domain). If unset, uses /api/contact
# VITE_CONTACT_API_URL=https://your-project.vercel.app/api/contact

# =============================================================================
# Vercel (set in Dashboard → Settings → Environment Variables, not in this file)
# =============================================================================
# MONGODB_URI=mongodb+srv://...          # required for /api/contact on Vercel
# MONGODB_DB_NAME=...                    # optional; else DB name from URI
# MONGODB_CONTACTS_COLLECTION=sejal_contacts   # optional
# OFFICE_ADDRESS=...                     # optional defaults in api/contact.js
# OFFICE_MAPS_URL=...                    # optional
